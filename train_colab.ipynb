{
  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# 🚀 LLM Full Pipeline on Google Colab\n",
        "\n",
        "This notebook covers the entire lifecycle of your custom transformer: **Pretraining**, **Supervised Fine-Tuning (SFT)**, and **Inference**.\n",
        "\n",
        "## 1. Environment Setup"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 📂 Mount Google Drive\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Create directories on Drive\n",
        "BASE_DRIVE = \"/content/drive/MyDrive/llm_scratch\"\n",
        "PRETRAIN_DIR = f\"{BASE_DRIVE}/pretrain_checkpoints\"\n",
        "SFT_DIR = f\"{BASE_DRIVE}/sft_checkpoints\"\n",
        "DATA_DIR = f\"{BASE_DRIVE}/training_data\"\n",
        "\n",
        "!mkdir -p \"{PRETRAIN_DIR}\"\n",
        "!mkdir -p \"{SFT_DIR}\"\n",
        "!mkdir -p \"{DATA_DIR}\"\n",
        "\n",
        "print(f\"Using Drive path: {BASE_DRIVE}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 🛠️ Install Dependencies\n",
        "import torch\n",
        "print(f\"Using GPU: {torch.cuda.get_device_name(0)}\")\n",
        "\n",
        "# Install CUDA-optimized dependencies\n",
        "!pip install -r requirements_cuda.txt\n",
        "\n",
        "try:\n",
        "    import xformers\n",
        "    print(\"xformers already installed\")\n",
        "except ImportError:\n",
        "    !pip install xformers"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Pretraining\n",
        "First, we train the model on raw text (PDFs, Ebooks, etc.) to learn language patterns."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 📦 Prepare Pretraining Data\n",
        "# This will process all PDFs/EPUBs in your Google Drive 'training_data' folder\n",
        "print(f\"Processing files from: {DATA_DIR}\")\n",
        "!python dataset.py --data_dir \"{DATA_DIR}\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 🏃 Run Pretraining\n",
        "CONFIG = \"colab_max\" # @param [\"nano\", \"small\", \"medium\", \"colab\", \"colab_max\"]\n",
        "BATCH_SIZE = 1 # @param {type:\"integer\"}\n",
        "GRAD_ACCUM = 16 # @param {type:\"integer\"}\n",
        "RESUME = True # @param {type:\"boolean\"}\n",
        "GRAD_CHECKPOINT = True # @param {type:\"boolean\"}\n",
        "\n",
        "resume_flag = \"--resume\" if RESUME else \"\"\n",
        "gc_flag = \"--grad_checkpoint\" if GRAD_CHECKPOINT else \"\"\n",
        "\n",
        "# Note: For colab_max, we recommend BATCH_SIZE=1 and higher GRAD_ACCUM to save memory\n",
        "!python train.py \\\n",
        "    --config {CONFIG} \\\n",
        "    --data_dir \"{DATA_DIR}\" \\\n",
        "    --checkpoint_dir \"{PRETRAIN_DIR}\" \\\n",
        "    --batch_size {BATCH_SIZE} \\\n",
        "    --grad_accum {GRAD_ACCUM} \\\n",
        "    {resume_flag} \\\n",
        "    {gc_flag}"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Supervised Fine-Tuning (SFT)\n",
        "Now we take the pretrained model and teach it to follow instructions using the 8,400 samples we just integrated."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 🎯 Run SFT Training\n",
        "PRETRAINED_CHECKPOINT = \"/content/drive/MyDrive/llm_scratch/pretrain_checkpoints/step_500.pt\" # @param {type:\"string\"}\n",
        "SFT_BATCH_SIZE = 1 # @param {type:\"integer\"}\n",
        "SFT_GRAD_ACCUM = 16 # @param {type:\"integer\"}\n",
        "MAX_SFT_STEPS = 2000 # @param {type:\"integer\"}\n",
        "SFT_GRAD_CHECKPOINT = True # @param {type:\"boolean\"}\n",
        "\n",
        "gc_flag = \"--grad_checkpoint\" if SFT_GRAD_CHECKPOINT else \"\"\n",
        "\n",
        "!python sft_train.py \\\n",
        "    --checkpoint \"{PRETRAINED_CHECKPOINT}\" \\\n",
        "    --data sft_data/train.jsonl \\\n",
        "    --output_dir \"{SFT_DIR}\" \\\n",
        "    --batch_size {SFT_BATCH_SIZE} \\\n",
        "    --grad_accum {SFT_GRAD_ACCUM} \\\n",
        "    --max_steps {MAX_SFT_STEPS} \\\n",
        "    {gc_flag}"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Interactive Chat\n",
        "Test your model!"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# @title 💬 Chat with your Model\n",
        "SFT_CHECKPOINT = \"/content/drive/MyDrive/llm_scratch/sft_checkpoints/sft_final.pt\" # @param {type:\"string\"}\n",
        "\n",
        "!python chat.py --checkpoint \"{SFT_CHECKPOINT}\""
      ]
    }
  ],\n",
